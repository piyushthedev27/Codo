# Frontend Environment Variables
# Copy this file to .env and fill in your Firebase project values

# Firebase Client Config (from Firebase Console → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# Backend API URL (change for production)
VITE_API_URL=http://localhost:3000
